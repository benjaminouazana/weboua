# ──────────────────────────────────────────────────────────
# Weboua — variables d'environnement
# Copiez ce fichier en `.env.local` et remplissez les valeurs.
# Ne committez JAMAIS le fichier .env.local (il contient des secrets).
# ──────────────────────────────────────────────────────────

# URL de production (utilisée pour le SEO, le sitemap, les canonicals)
NEXT_PUBLIC_SITE_URL=https://weboua.com

# ── Leads → Google Sheets ──────────────────────────────────
# 1. Créez un projet Google Cloud + activez l'API Google Sheets
# 2. Créez un compte de service, téléchargez la clé JSON
# 3. Partagez votre Google Sheet avec l'email du compte de service (droit Éditeur)
GOOGLE_SERVICE_ACCOUNT_EMAIL=xxxx@xxxx.iam.gserviceaccount.com
# Collez la clé privée entre guillemets, avec les \n littéraux conservés
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# ID du Google Sheet (la partie entre /d/ et /edit dans l'URL)
GOOGLE_SHEET_ID=
# Onglet + plage où ajouter les lignes (par défaut "Leads!A:I")
GOOGLE_SHEET_RANGE=Leads!A:I

# ── Leads → Email (Resend) ─────────────────────────────────
# Clé API Resend (https://resend.com)
RESEND_API_KEY=
# Adresse qui reçoit une copie de chaque lead
LEAD_NOTIFY_EMAIL=contact@weboua.com
# Expéditeur (le domaine doit être vérifié dans Resend)
LEAD_FROM_EMAIL="Weboua <leads@weboua.com>"
